# Database
DATABASE_URL=postgresql://user:password@host/database
DATABASE_POOL_URL=postgresql://user:password@host/database?schema=public
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/database
MONGODB_NAME=eshraman_main

# Redis
UPSTASH_REDIS_REST_URL=https://...
UPSTASH_REDIS_REST_TOKEN=...
UPSTASH_REDIS_URL=redis://...

# Storage
BACKBLAZE_BUCKET_NAME=eshraman-jainism
BACKBLAZE_BUCKET_ID=...
BACKBLAZE_APP_KEY_ID=...
BACKBLAZE_APP_KEY=...

# Services
FIREBASE_PROJECT_ID=...
FIREBASE_PRIVATE_KEY=...
FIREBASE_CLIENT_EMAIL=...
SENDGRID_API_KEY=...
SENDGRID_FROM_EMAIL=...
GOOGLE_MAPS_API_KEY=...
RAZORPAY_KEY_ID=...
RAZORPAY_KEY_SECRET=...
RECAPTCHA_SITE_KEY=...
RECAPTCHA_SECRET_KEY=...

# Monitoring
SENTRY_DSN=https://...
SENTRY_ENVIRONMENT=development

# JWT
JWT_SECRET=your-secret-key-min-32-characters-change-this
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# Server
NODE_ENV=development
PORT=3000

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:5173,http://localhost:19000

# API
API_VERSION=v1
